-- 2. LISTA (LÍMITE 2)
local items = {["Fake Designer Bag"]=2, ["Fake Watch"]=2, ["Sarsaparilla"]=2, ["Taco"]=2, ["Bloxy Cola"]=2}

local function getQty(name)
    local c, s = 0, name:lower()
    for _, v in pairs(p.Backpack:GetChildren()) do if v.Name:lower():find(s) then c+=1 end end
    local t = char:FindFirstChildWhichIsA("Tool"); if t and t.Name:lower():find(s) then c+=1 end
    return c
end

-- 3. MOTOR NOCLIP & ROTACIÓN
local noclipLoop = nil
local function toggleNoclip(state)
    if state then
        if not noclipLoop then
            noclipLoop = rs.Stepped:Connect(function()
                if not char then return end
                for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
            end)
        end
    else
        if noclipLoop then noclipLoop:Disconnect(); noclipLoop = nil end
    end
end

local function focus(targetPos)
    hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z))
end

-- 4. MOTOR TP VEHICLE (MOBILE SNAPPY)
local function safeVehicleTP(dest, autoDismount, seat)
    local veh = seat and seat:FindFirstAncestorOfClass("Model")
    if veh then
        for _, part in pairs(veh:GetDescendants()) do 
            if part:IsA("BasePart") then part.Anchored = true; part.AssemblyLinearVelocity = Vector3.zero end 
        end
        local _, sz = veh:GetBoundingBox()
        veh:PivotTo(CFrame.new(dest.X, dest.Y + (sz.Y/2) + 0.3, dest.Z) * CFrame.Angles(0, math.rad(3), 0))
        task.wait(0.3) -- Más rápido para móvil
        for _, part in pairs(veh:GetDescendants()) do if part:IsA("BasePart") then part.Anchored = false end end
    end
    if autoDismount then
        hum.Sit = false; task.wait(0.1)
        hrp.Anchored = true
        hrp.CFrame = CFrame.new(dest.X + 8, dest.Y + 2, dest.Z)
        task.wait(0.1)
        hrp.Anchored = false
        hum:ChangeState(Enum.HumanoidStateType.Freefall)
    end
end

-- 5. MOTOR COMPRA Y GRAP
local function AutoBuy(segundos)
    local endTime = tick() + segundos
    while tick() < endTime do
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local pPart = obj.Parent:IsA("BasePart") and obj.Parent or obj.Parent.Parent
                if pPart and pPart:IsA("BasePart") and (pPart.Position - hrp.Position).Magnitude <= 18 then
                    local txt = (obj.ObjectText .. obj.ActionText):lower()
                    for item, maxQty in pairs(items) do
                        if txt:find(item:lower()) and getQty(item) < maxQty then
                            focus(pPart.Position)
                            obj.HoldDuration = 0; fireproximityprompt(obj); task.wait(0.05)
                        end
                    end
                end
            end
        end
        task.wait()
    end
end

local function AutoInteract(keywords, waitAfter)
    local startTime = tick()
    while tick() - startTime < 4 do
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local pPart = obj.Parent:IsA("BasePart") and obj.Parent or obj.Parent.Parent
                if pPart and pPart:IsA("BasePart") and (pPart.Position - hrp.Position).Magnitude <= 18 then
                    local txt = (obj.ObjectText .. obj.ActionText):lower()
                    for _, kw in pairs(keywords) do
                        if txt:find(kw) then
                            focus(pPart.Position)
                            local interactEnd = tick() + waitAfter
                            while tick() < interactEnd do
                                obj.HoldDuration = 0; fireproximityprompt(obj); task.wait(0.1) 
                            end
                            return true
                        end
                    end
                end
            end
        end
        task.wait(0.2)
    end
end

