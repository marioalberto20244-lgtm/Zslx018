-- // 3. BUSCADOR EXACTO POR MENTE (CERO LÍNEAS ROJAS) // --
local function GetMurderer()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            -- Solo checamos la mente del servidor (RoleCache)
            if getgenv().RoleCache[p.Name] and getgenv().RoleCache[p.Name].Role == "Murderer" then
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    return p.Character.HumanoidRootPart
                end
            end
        end
    end
    return nil
end

-- // 4. 🛠️ FIX MAESTRO: REDIRECCIÓN SILENT AIM (HOOK) // --
-- Esto es lo que evita que el tiro se vaya a donde apuntas
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    -- Si el juego intenta disparar y tenemos un modo activo...
    if tostring(self) == "Shoot" and method == "FireServer" then
        if getgenv().AutoShoot_Active or getgenv().ManualShoot_Active then
            local murd = GetMurderer()
            if murd then
                -- Predicción para darle en movimiento
                local Prediction = 0.175 
                local TargetPos = murd.Position + (murd.AssemblyLinearVelocity * Prediction)
                
                -- Obligamos a la bala a ir al Murderer, ignorando a dónde tocaste
                args[1] = CFrame.new(TargetPos + Vector3.new(0, 0.6, 0)) -- Origen (Wallbang)
                args[2] = CFrame.new(TargetPos) -- Destino (Frente del Murderer)
                
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

-- // 5. WALLCHECK (VISIÓN DE RAYOS X PARA EL MODO AUTO) // --
local function IsVisible(targetPart)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("Head") then return false end
    
    local origin = char.Head.Position
    local direction = (targetPart.Position - origin)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char, Workspace.CurrentCamera}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local result = Workspace:Raycast(origin, direction, raycastParams)
    
    if not result or result.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end
    return false
end

-- // 6. SISTEMA DE EJECUCIÓN CORTA (EQUIPA, TIRA BASURA Y GUARDA) // --
local isShooting = false
local function ExecuteKill()
    if isShooting then return end
    local char = LocalPlayer.Character
    local backpack = LocalPlayer.Backpack
    if not char then return end
    
    local gun = char:FindFirstChild("Gun") or backpack:FindFirstChild("Gun")
    if gun then
        isShooting = true
        
        -- Equipa
        if gun.Parent ~= char then 
            char.Humanoid:EquipTool(gun) 
            task.wait(0.15) -- Tiempo de sincronización para celular
        end
        
        -- Dispara (Mandamos coordenadas falsas, el Hook de arriba las corrige solitas)
        local shootRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Gameplay"):WaitForChild("Shoot")
        shootRemote:FireServer(char.HumanoidRootPart.CFrame, char.HumanoidRootPart.CFrame)
        
        -- Guarda el arma
        task.wait(0.05)
        gun.Parent = backpack
        
        task.wait(0.3)
        isShooting = false
    end
end

-- // 7. MODO AUTO: BUCLE ASESINO // --
task.spawn(function()
    while true do
        task.wait(0.1)
        if getgenv().AutoShoot_Active and not isShooting then
            local murd = GetMurderer()
            -- Si existe y ESTÁ VISIBLE (Wallcheck)
            if murd and IsVisible(murd) then
                ExecuteKill()
            end
        end
    end
end)

-- // 8. MODO MANUAL: GATILLO DE PANTALLA (WALLBANG) // --
local TouchStart = 0
local StartPos = Vector2.new(0,0)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end 
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and getgenv().ManualShoot_Active then 
        TouchStart = tick()
        StartPos = input.Position 
    end
end)

UserInputService.InputEnded:Connect(function(input, gp)
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and getgenv().ManualShoot_Active then
        local Dur = tick() - TouchStart
        local Dist = (Vector2.new(input.Position.X, input.Position.Y) - Vector2.new(StartPos.X, StartPos.Y)).Magnitude
        
        -- Si fue un toque rápido y no estamos disparando ya
        if Dur < 0.25 and Dist < 20 and not isShooting then 
            local murd = GetMurderer()
            -- Si el Murderer existe, disparamos ignorando paredes
            if murd then
                ExecuteKill() 
            end
        end
    end
end)

























