-- // 5. WALLCHECK (PARA EL MODO AUTO) // --
local function IsVisible(targetPart)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("Head") then return false end
    
    local origin = char.Head.Position
    local direction = (targetPart.Position - origin)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char, Workspace.CurrentCamera}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local result = Workspace:Raycast(origin, direction, raycastParams)
    
    if not result or result.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end
    return false
end

-- // 6. SISTEMA DE EJECUCIÓN EXACTO (CÓMO EL TUYO) // --
local isShooting = false
local function ExecuteKill()
    if isShooting then return end
    
    local char = LocalPlayer.Character
    local backpack = LocalPlayer.Backpack
    local target = getgenv().CurrentTarget
    
    if not char or not target then return end
    
    local gun = char:FindFirstChild("Gun") or backpack:FindFirstChild("Gun")
    if gun then
        isShooting = true
        
        -- 1. EQUIPA
        if gun.Parent ~= char then 
            char.Humanoid:EquipTool(gun) 
            task.wait(0.12) -- Delay para el server
        end
        
        -- 2. DISPARA (El hook hace la magia)
        local shoot = gun:FindFirstChild("Shoot")
        if shoot then 
            shoot:FireServer(char.HumanoidRootPart.CFrame, char.HumanoidRootPart.CFrame) 
        end
        
        -- 3. GUARDA
        task.wait(0.05)
        gun.Parent = backpack
        
        task.wait(0.3)
        isShooting = false
    end
end

-- // 7. MODO AUTO: BUCLE ASESINO // --
task.spawn(function()
    while true do
        task.wait(0.1)
        if getgenv().AutoShoot_Active and not isShooting then
            local target = getgenv().CurrentTarget
            -- Si ya sabemos quién es y lo estamos viendo de frente:
            if target and IsVisible(target) then
                ExecuteKill()
            end
        end
    end
end)

-- // 8. MODO MANUAL: GATILLO DE PANTALLA // --
local TouchStart = 0
local StartPos = Vector2.new(0,0)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end 
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and getgenv().ManualShoot_Active then 
        TouchStart = tick()
        StartPos = input.Position 
    end
end)

UserInputService.InputEnded:Connect(function(input, gp)
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and getgenv().ManualShoot_Active then
        local Dur = tick() - TouchStart
        local Dist = (Vector2.new(input.Position.X, input.Position.Y) - Vector2.new(StartPos.X, StartPos.Y)).Magnitude
        
        if Dur < 0.25 and Dist < 20 and not isShooting then 
            -- Si es manual, no ocupamos Wallcheck. Si el target existe, tira:
            if getgenv().CurrentTarget then
                ExecuteKill() 
            end
        end
    end
end)
























