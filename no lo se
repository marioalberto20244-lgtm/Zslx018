-- // 3. BUSCADOR EXACTO (SOLO MURDERER) // --
local function GetMurderer()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            -- Solo checamos el rol del servidor, nada de buscar el cuchillo visualmente
            if getgenv().RoleCache[p.Name] and getgenv().RoleCache[p.Name].Role == "Murderer" then
                -- Checamos que siga vivo
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    return p.Character.HumanoidRootPart
                end
            end
        end
    end
    return nil
end

-- // 4. WALLCHECK (VISIÓN DE RAYOS X PARA EL MODO AUTO) // --
local function IsVisible(targetPart)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("Head") then return false end
    
    local origin = char.Head.Position
    local direction = (targetPart.Position - origin)
    
    local raycastParams = RaycastParams.new()
    -- Ignoramos nuestro cuerpo y la cámara para que no bloqueen el rayo
    raycastParams.FilterDescendantsInstances = {char, Workspace.CurrentCamera}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local result = Workspace:Raycast(origin, direction, raycastParams)
    
    -- Si no chocó con nada, o chocó con una parte del enemigo, lo estamos viendo
    if not result or result.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end
    return false
end

-- // 5. SISTEMA DE EJECUCIÓN (EQUIPA, DISPARA Y GUARDA) // --
local isShooting = false
local function ExecuteKill(target)
    if isShooting then return end
    
    local char = LocalPlayer.Character
    local backpack = LocalPlayer.Backpack
    if not char or not target then return end
    
    local gun = char:FindFirstChild("Gun") or backpack:FindFirstChild("Gun")
    if gun then
        isShooting = true
        
        -- 1. Equipa
        if gun.Parent ~= char then 
            char.Humanoid:EquipTool(gun) 
            task.wait(0.12) -- Espera para PC/Mobile sync
        end
        
        -- 2. Predicción y Tiro Remoto
        local ping = tonumber(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValueString():split(" ")[1]) or 50
        local Prediction = (ping / 2500) + 0.175
        local TargetPos = target.Position + (target.AssemblyLinearVelocity * Prediction)
        
        local shootRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Gameplay"):WaitForChild("Shoot")
        -- Manda el tiro
        shootRemote:FireServer(CFrame.new(TargetPos + Vector3.new(0, 0.6, 0)), CFrame.new(TargetPos))
        
        -- 3. Guarda el arma
        task.wait(0.05)
        gun.Parent = backpack
        
        -- Cooldown para no saturar
        task.wait(0.5)
        isShooting = false
    end
end

-- // 6. MODO AUTO: BUCLE ASESINO // --
task.spawn(function()
    while true do
        task.wait(0.1) -- Escanea cada 0.1 segundos
        if getgenv().AutoShoot_Active then
            local murd = GetMurderer()
            -- Si existe y lo podemos ver (Wallcheck aprobado), lo revienta
            if murd and IsVisible(murd) then
                ExecuteKill(murd)
            end
        end
    end
end)

-- // 7. MODO MANUAL: GATILLO DE PANTALLA // --
local TouchStart = 0
local StartPos = Vector2.new(0,0)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end 
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and getgenv().ManualShoot_Active then 
        TouchStart = tick()
        StartPos = input.Position 
    end
end)

UserInputService.InputEnded:Connect(function(input, gp)
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and getgenv().ManualShoot_Active then
        local Dur = tick() - TouchStart
        local Dist = (Vector2.new(input.Position.X, input.Position.Y) - Vector2.new(StartPos.X, StartPos.Y)).Magnitude
        
        -- Si fue un toque/click rápido
        if Dur < 0.25 and Dist < 20 then 
            local murd = GetMurderer()
            if murd then
                ExecuteKill(murd) -- Se ejecuta SIN wallcheck (Wallbang directo)
            end
        end
    end
end)

























