local items = {["Fake Designer Bag"]=3, ["Fake Watch"]=3, ["Sarsaparilla"]=4}

local function getQty(name)
    local c, s = 0, name:lower()
    for _, v in pairs(p.Backpack:GetChildren()) do if v.Name:lower():find(s) then c+=1 end end
    local t = char:FindFirstChildWhichIsA("Tool"); if t and t.Name:lower():find(s) then c+=1 end
