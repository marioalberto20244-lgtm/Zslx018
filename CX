-- 🧠 CEREBRO: AUTO-FARM v44.8.4 "TRUE FIX EDITION" (SMART INV + TRUE DEATH)
-- Optimizado por Zslx: Adiós Anclaje. Fix definitivo del Fling en primer TP.
-- ==============================================================================
local p = game.Players.LocalPlayer
local rs = game:GetService("RunService")
local vim = game:GetService("VirtualInputManager") 

local char, hum, hrp
local miAsiento = nil 
local noclipLoop = nil
local farmLoopActive = false

local function refreshVars()
    char = p.Character or p.CharacterAdded:Wait()
    hum = char:WaitForChild("Humanoid")
    hrp = char:WaitForChild("HumanoidRootPart")
end
refreshVars()

local items = {["Fake Designer Bag"]=3, ["Fake Watch"]=3, ["Sarsaparilla"]=4}

local function getQty(name)
    local c, s = 0, name:lower()
    for _, v in pairs(p.Backpack:GetChildren()) do if v.Name:lower():find(s) then c+=1 end end
    local t = char:FindFirstChildWhichIsA("Tool"); if t and t.Name:lower():find(s) then c+=1 end
    return c
end

local function hasAllItems()
    for item, maxQty in pairs(items) do
        if getQty(item) < maxQty then return false end
    end
    return true
end

local function hasNoItems()
    for item, _ in pairs(items) do
        if getQty(item) > 0 then return false end
    end
    return true
end

-- 3. MOTOR NOCLIP
local function toggleNoclip(state)
    if state then
        if not noclipLoop then
            noclipLoop = rs.Stepped:Connect(function()
                if not char then return end
                for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
            end)
        end
    else
        if noclipLoop then noclipLoop:Disconnect(); noclipLoop = nil end
    end
end

-- ==========================================================
-- CANDADO DE ASIENTO ULTRA RÁPIDO (INSTA-SIT CON FIX DE PEGAMENTO)
-- ==========================================================
local function EnsureSit()
    if not miAsiento or not _G.Z_Farm_Active then return end
    toggleNoclip(false)
    
    if hum.SeatPart == miAsiento then return end 

    while hum.SeatPart ~= miAsiento and _G.Z_Farm_Active do
        hrp.CFrame = miAsiento.CFrame 
        miAsiento:Sit(hum)
        task.wait() 
    end
    -- FIX: Le damos 0.2s al servidor para que procese el "SeatWeld" y no te deje tirado
    task.wait(0.2)
end

-- ==========================================================
-- MOTOR TP VEHICLE (CERO FLING, CERO ANCLAJE)
-- ==========================================================
local function safeVehicleTP(dest)
    if not miAsiento or not miAsiento.Parent then return end 
    local veh = miAsiento:FindFirstAncestorOfClass("Model")
    if veh then
        -- 1. Matar momentum ANTES del TP
        for _, part in pairs(veh:GetDescendants()) do 
            if part:IsA("BasePart") then 
                part.AssemblyLinearVelocity = Vector3.zero 
                part.AssemblyAngularVelocity = Vector3.zero 
            end 
        end
        local _, sz = veh:GetBoundingBox()
        
        -- 2. Teletransportar
        veh:PivotTo(CFrame.new(dest.X, dest.Y + (sz.Y/2) + 0.3, dest.Z) * CFrame.Angles(0, math.rad(3), 0))
        
        -- 3. FIX FLING PRIMER TP: Volver a matar momentum DESPUÉS del TP al instante
        for _, part in pairs(veh:GetDescendants()) do 
            if part:IsA("BasePart") then 
                part.AssemblyLinearVelocity = Vector3.zero 
                part.AssemblyAngularVelocity = Vector3.zero 
            end 
        end
        
        task.wait(0.1) 
    end
end

