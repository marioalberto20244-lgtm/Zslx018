-- 5. MOTORES INTELIGENTES
-- ==========================================================
local function SmartBuy()
    local endTime = tick() + 8 
    while not hasAllItems() and tick() < endTime and _G.Z_Farm_Active do
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local pPart = obj.Parent:IsA("BasePart") and obj.Parent or obj.Parent.Parent
                if pPart and pPart:IsA("BasePart") and (pPart.Position - hrp.Position).Magnitude <= 18 then
                    local txt = (obj.ObjectText .. obj.ActionText):lower()
                    for item, maxQty in pairs(items) do
                        if txt:find(item:lower()) and getQty(item) < maxQty then
                            obj.HoldDuration = 0; fireproximityprompt(obj); task.wait() 
                        end
                    end
                end
            end
        end
        task.wait(0.03)
    end
end

local function SmartSell()
    local endTime = tick() + 8
    while not hasNoItems() and tick() < endTime and _G.Z_Farm_Active do
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local pPart = obj.Parent:IsA("BasePart") and obj.Parent or obj.Parent.Parent
                if pPart and pPart:IsA("BasePart") and (pPart.Position - hrp.Position).Magnitude <= 18 then
                    local txt = (obj.ObjectText .. obj.ActionText):lower()
                    if txt:find("sell") or txt:find("smuggle") then
                        obj.HoldDuration = 0; fireproximityprompt(obj); task.wait(0.05)
                    end
                end
            end
        end
        task.wait(0.1)
    end
end

local function SmartWash()
    local endTime = tick() + 8
    while getQty("Briefcase") > 0 and tick() < endTime and _G.Z_Farm_Active do
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local pPart = obj.Parent:IsA("BasePart") and obj.Parent or obj.Parent.Parent
                if pPart and pPart:IsA("BasePart") and (pPart.Position - hrp.Position).Magnitude <= 18 then
                    local txt = (obj.ObjectText .. obj.ActionText):lower()
                    if txt:find("laundry") or txt:find("dirty") then
                        obj.HoldDuration = 0; fireproximityprompt(obj); task.wait(0.05)
                    end
                end
            end
        end
        task.wait(0.1)
    end
end

-- ==========================================================
-- FASE 1 PREMIUM: SIMULADOR DE CLICS
-- ==========================================================
local function forceUIClick(textoBoton)
    for _, gui in pairs(p.PlayerGui:GetDescendants()) do
        if gui:IsA("TextButton") and gui.Visible and gui.AbsolutePosition.X > 0 then
            if gui.Text:lower():find(textoBoton:lower()) then
                local x = gui.AbsolutePosition.X + (gui.AbsoluteSize.X / 2)
                local y = gui.AbsolutePosition.Y + (gui.AbsoluteSize.Y / 2) + 36 
                vim:SendMouseButtonEvent(x, y, 0, true, game, 1)
                task.wait(0.05)
                vim:SendMouseButtonEvent(x, y, 0, false, game, 1)
                return true
            end
        end
    end
    return false
end

local function AutoGetCarPremium()
    local endT = tick() + 12 
    hrp.CFrame = CFrame.new(-1947, 3.5, 55); task.wait(0.3) 

    while not hum.SeatPart and tick() < endT and _G.Z_Farm_Active do
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and (obj.Position - hrp.Position).Magnitude < 15 then
                local txt = (obj.ObjectText .. obj.ActionText):lower()
                if txt:find("spawn") or txt:find("vehicle") then
                    obj.HoldDuration = 0; fireproximityprompt(obj); task.wait(0.5) 
                end
            end
        end

        if forceUIClick("select") then task.wait(0.5) end
        if forceUIClick("spawn") then task.wait(1.5) end 

        -- NOS SENTAMOS Y ESPERAMOS SIN ANCLAR NADA
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("VehicleSeat") and (obj.Position - hrp.Position).Magnitude < 30 then
                obj:Sit(hum)
                if hum.SeatPart then
                    miAsiento = hum.SeatPart
                    task.wait(1) -- Solo dejamos que el server lo procese natural we
                    return 
                end
            end
        end
        task.wait(0.2)
    end
end

