-- // 🎯 FUNCIÓN QUIRÚRGICA PARA CADA ARMA // --
local function ApplyHacks(v)
    if type(v) ~= "table" or not rawget(v, "gunName") then return end
    local gName = tostring(v.gunName):lower()

    -- 1. 🔥 FIREMODES (LO QUE SIEMPRE TE JALA)
    if _G.Z_GunMods_Burst then
        if gName:find("hi%-point") or (gName:find("glock") and not gName:find("switch")) then
            v.ShootType = 2 -- Burst
            v.BurstShot = 3
            if v.FireModes then v.FireModes.Burst = true; v.FireModes.Auto = false end
        elseif gName:find("tec%-9") or gName:find("glock switch") or gName:find("ar%-15") or gName:find("ak%-47") then
            v.ShootType = 3 -- Auto
            if v.FireModes then v.FireModes.Burst = false; v.FireModes.Auto = true end
        end
    end

    -- 2. ♾️ BALAS INF (METODO AGRESIVO)
    if _G.Z_GunMods_InfAmmo then
        v.AmmoInGun = 999
        v.Ammo = 999
        v.StoredAmmo = 999
        v.MaxStoredAmmo = 999
        if v.Jammed ~= nil then v.Jammed = false end
    end

    -- 3. 🎯 NO RECOIL
    if _G.Z_GunMods_NoRecoil then
        v.MinSpread, v.MaxSpread, v.Recoil = 0, 0, 0
        if v.camRecoil then for i, _ in pairs(v.camRecoil) do v.camRecoil[i] = {0,0} end end
        if v.gunRecoil then for i, _ in pairs(v.gunRecoil) do v.gunRecoil[i] = {0,0} end end
    end
end

-- // ⚡ BUCLE DE INYECCIÓN CONSTANTE (PARA QUE NO "REGISTRE" NADA MAL) // --
task.spawn(function()
    while gunLoopActive do
        task.wait() -- VELOCIDAD MÁXIMA (Sin lag)
        
        if _G.Z_GunMods_Active then
