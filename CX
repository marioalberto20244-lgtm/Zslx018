local function EnsureSit()
    if not miAsiento or not _G.Z_Farm_Active then return end
    toggleNoclip(false)
    
    if hum.SeatPart == miAsiento then return end 

    while hum.SeatPart ~= miAsiento and _G.Z_Farm_Active do
        hrp.CFrame = miAsiento.CFrame 
        miAsiento:Sit(hum)
        task.wait() 
    end
    -- FIX: Le damos 0.2s al servidor para que procese el "SeatWeld" y no te deje tirado
    task.wait(0.2)
end

-- ==========================================================
-- MOTOR TP VEHICLE (CERO FLING, CERO ANCLAJE)
-- ==========================================================
local function safeVehicleTP(dest)
    if not miAsiento or not miAsiento.Parent then return end 
    local veh = miAsiento:FindFirstAncestorOfClass("Model")
    if veh then
        -- 1. Matar momentum ANTES del TP
        for _, part in pairs(veh:GetDescendants()) do 
            if part:IsA("BasePart") then 
                part.AssemblyLinearVelocity = Vector3.zero 
                part.AssemblyAngularVelocity = Vector3.zero 
            end 
        end
        local _, sz = veh:GetBoundingBox()
        
        -- 2. Teletransportar
        veh:PivotTo(CFrame.new(dest.X, dest.Y + (sz.Y/2) + 0.3, dest.Z) * CFrame.Angles(0, math.rad(3), 0))
        
        -- 3. FIX FLING PRIMER TP: Volver a matar momentum DESPUÉS del TP al instante
        for _, part in pairs(veh:GetDescendants()) do 
            if part:IsA("BasePart") then 
                part.AssemblyLinearVelocity = Vector3.zero 
                part.AssemblyAngularVelocity = Vector3.zero 
            end 
        end
        
        task.wait(0.1) 
    end
end

