    local function ClearSkeleton(player)
        if Skeletons[player] then
            for _, group in pairs(Skeletons[player]) do
                for _, line in pairs(group) do
                    line.Visible = false
                    line:Remove() 
                end
            end
            Skeletons[player] = nil
        end
    end

