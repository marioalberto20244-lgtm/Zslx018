    local function CreateLine()
        local line = Drawing.new("Line")
        line.Thickness = 1.5 
        line.Transparency = 1
        line.Visible = false
        return line
    end

    -- Estructura de huesos
    local function CreateSkeleton()
        return {
            Spine = {CreateLine(), CreateLine()}, 
            Arms = {CreateLine(), CreateLine(), CreateLine(), CreateLine()}, 
            Legs = {CreateLine(), CreateLine(), CreateLine(), CreateLine()}  
        }
    end

