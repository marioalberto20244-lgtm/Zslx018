-- // 🧠 MOTOR HI-POINT & ACS PRO (ULTRA PRECISION) // --

local lastWeaponUpdate = 0
local Originals = {}

local function PatchWeapons()
    for _, v in pairs(getgc(true)) do
        if type(v) == "table" then
            
            -- --- 4. NO RECOIL & NO SPREAD (FIX PARA EL BAILOTEO DE BALAS) ---
            -- Buscamos si la tabla tiene datos de Recoil o Spread
            if rawget(v, "camRecoil") or rawget(v, "gunRecoil") or rawget(v, "RecoilPowerStepAmount") then
                if _G.Z_NoRecoil then
                    -- Respaldamos originales para poder apagarlo luego
                    if not Originals[v] then
                        Originals[v] = {
                            MinSpread = v.MinSpread,
                            MaxSpread = v.MaxSpread,
                            MinRecoilPower = v.MinRecoilPower,
                            MaxRecoilPower = v.MaxRecoilPower,
                            Recoil = v.Recoil
                        }
                    end

                    -- [[ LÓGICA ULTRA OP ]] --
                    v.MinSpread = 0
                    v.MaxSpread = 0
                    v.AimInaccuracyStepAmount = 0
                    v.AimInaccuracyDecrease = 10 -- Recuperación instantánea
                    
                    v.MinRecoilPower = 0
                    v.MaxRecoilPower = 0
                    v.RecoilPowerStepAmount = 0
                    v.Recoil = 0 -- Variable estándar

                    -- Reseteamos los ángulos de cámara (ACS / Hi-Point)
                    if v.camRecoil then
                        v.camRecoil.camRecoilUp = {0,0}
                        v.camRecoil.camRecoilTilt = {0,0}
                        v.camRecoil.camRecoilLeft = {0,0}
                        v.camRecoil.camRecoilRight = {0,0}
                    end
                    -- Reseteamos los ángulos del arma
                    if v.gunRecoil then
                        v.gunRecoil.gunRecoilUp = {0,0}
                        v.gunRecoil.gunRecoilTilt = {0,0}
                        v.gunRecoil.gunRecoilLeft = {0,0}
                        v.gunRecoil.gunRecoilRight = {0,0}
                        v.gunRecoil.DownPunch = 0
                    end
                else
                    -- SI EL HACK ESTÁ OFF: Restauramos valores
                    if Originals[v] then
                        v.MinSpread = Originals[v].MinSpread
                        v.MaxSpread = Originals[v].MaxSpread
                        v.MinRecoilPower = Originals[v].MinRecoilPower
                        v.MaxRecoilPower = Originals[v].MaxRecoilPower
                        v.Recoil = Originals[v].Recoil
                        -- No limpiamos Originals[v] aquí por si falta el Inf Ammo
                    end
                end
            end
            
            -- --- LÓGICA INF AMMO (FIX PARA HI-POINT / ACS) ---
            if rawget(v, "AmmoInGun") or rawget(v, "MaxStoredAmmo") or rawget(v, "Ammo") then
                if _G.Z_InfAmmo then
                    v.AmmoInGun = math.huge 
                    v.Ammo = math.huge
                    v.StoredAmmo = math.huge
                    v.MaxStoredAmmo = math.huge 
                    if rawget(v, "Jammed") ~= nil then v.Jammed = false end
                end
            end

            -- Limpieza de memoria si ambos están apagados
            if not _G.Z_NoRecoil and not _G.Z_InfAmmo then Originals[v] = nil end
        end
    end
end

-- Loop de ejecución (0.2s para respuesta inmediata)
game:GetService("RunService").Heartbeat:Connect(function()
    if tick() - lastWeaponUpdate > 0.2 then
        lastWeaponUpdate = tick()
        
        pcall(PatchWeapons)
        
        -- Truco para objetos físicos en la Hi-Point (Visual)
        if _G.Z_InfAmmo then
            local char = game.Players.LocalPlayer.Character
