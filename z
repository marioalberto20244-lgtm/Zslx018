                        Camera:WorldToViewportPoint((cf * CFrame.new(-size.X/2, size.Y/2, size.Z/2)).Position),
                        Camera:WorldToViewportPoint((cf * CFrame.new(size.X/2, size.Y/2, size.Z/2)).Position),
                        Camera:WorldToViewportPoint((cf * CFrame.new(-size.X/2, -size.Y/2, size.Z/2)).Position),
                        Camera:WorldToViewportPoint((cf * CFrame.new(size.X/2, -size.Y/2, size.Z/2)).Position)
                    }

                    local function drawLine(line, p1, p2)
                        if p1.Z > 0 and p2.Z > 0 then
                            line.From = Vector2.new(p1.X, p1.Y)
                            line.To = Vector2.new(p2.X, p2.Y)
                            line.Color = color
                            line.Visible = true
                        else
                            line.Visible = false
                        end
                    end

                    -- Conectar las 12 líneas
                    drawLine(lines[1], points[1], points[2])
                    drawLine(lines[2], points[2], points[4])
                    drawLine(lines[3], points[4], points[3])
                    drawLine(lines[4], points[3], points[1])
                    drawLine(lines[5], points[5], points[6])
                    drawLine(lines[6], points[6], points[8])
                    drawLine(lines[7], points[8], points[7])
                    drawLine(lines[8], points[7], points[5])
                    drawLine(lines[9], points[1], points[5])
                    drawLine(lines[10], points[2], points[6])
                    drawLine(lines[11], points[3], points[7])
                    drawLine(lines[12], points[4], points[8])
                else
                    -- Ocultar si está muerto o desactivado
                    if Boxes[player] then
                        for _, line in pairs(Boxes[player]) do line.Visible = false end
                    end
                end
            end
        end
    end)
