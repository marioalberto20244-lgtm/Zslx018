-- [[ MOTOR Z-SLX: FIX FINAL (RE-FIXED) ]]
local s_p = "Si".."ze"
local h_p = "He".."ad"
local t_p = "Tor".."so"
local tr_p = "Trans".."parency"
local d_p = "Z".."Data".."99" 

game:GetService("RunService").Heartbeat:Connect(function()
    -- Solo entramos si está activo O si pedimos un reset forzado
    if not _G.Z_Hitbox_Active and not _G.Z_Force_Reset then return end
    
    local lp = game.Players.LocalPlayer
    local val_size = _G.Z_Hitbox_Size or 20
    local v_size = Vector3.new(val_size, val_size, val_size)

    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= lp and p.Character then
            local char = p.Character
            local is_team = _G.Z_Team_Check and lp.Team and p.Team == lp.Team
            
            -- >>> SECCIÓN DE LIMPIEZA (RESET) <<<
            -- Si el hitbox está apagado, o es equipo, o pedimos reset... LIMPIAMOS.
            if not _G.Z_Hitbox_Active or is_team or _G.Z_Force_Reset then
                for _, part in pairs(char:GetChildren()) do
                    local backup = part:FindFirstChild(d_p)
                    if backup then
                        part[s_p] = backup.Value      -- Restaurar tamaño
                        part[tr_p] = 0               -- Quitar transparencia
                        part.Material = Enum.Material.Plastic -- Quitar el Neon
                        backup:Destroy()             -- ¡IMPORTANTE! Borrar el backup
                    end
                end
                -- Si no está activo el hitbox, pasamos al siguiente jugador sin hacer nada más
                if not _G.Z_Hitbox_Active or is_team then continue end
            end

            -- >>> SECCIÓN DE APLICACIÓN <<<
            if _G.Z_Hitbox_Active then
                local targets = {}
                if _G.Z_Hitbox_Mode == "Head" then
                    table.insert(targets, char:FindFirstChild(h_p))
                elseif _G.Z_Hitbox_Mode == "Torso" then
                    table.insert(targets, char:FindFirstChild(t_p) or char:FindFirstChild("Upper"..t_p))
                elseif _G.Z_Hitbox_Mode == "Huesos" then
                    local bones = {"Left Arm", "Right Arm", "Left Leg", "Right Leg", "LeftUpperArm", "RightUpperArm"}
                    for _, b in pairs(bones) do 
                        local bp = char:FindFirstChild(b)
                        if bp then table.insert(targets, bp) end
                    end
                end

                for _, obj in pairs(targets) do
                    if obj and obj:IsA("BasePart") then
                        -- Solo guardamos el tamaño original si no lo hemos guardado ya
                        if not obj:FindFirstChild(d_p) then
                            local s = Instance.new("Vector3Value", obj)
                            s.Name = d_p
                            s.Value = obj[s_p]
                        end
                        
                        -- Aplicamos el Hitbox solo si el tamaño es diferente al deseado
                        if obj[s_p] ~= v_size then
                            obj[s_p] = v_size
                            obj[tr_p] = 0.6
                            obj.Color = Color3.fromRGB(255, 0, 0)
                            obj.Material = Enum.Material.Neon
                            obj.CanCollide = false
                            obj.Massless = true
                        end
                    end
                end
            end
        end
    end
    
    -- Una vez que terminamos de limpiar a todos, apagamos el reset forzado
    if _G.Z_Force_Reset then
        _G.Z_Force_Reset = false
    end
end)































