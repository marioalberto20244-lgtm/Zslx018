-- // 🔍 ESCANEO INTELIGENTE (CERO LAG) // --
-- Solo usamos getgc() cuando es ESTRICTAMENTE necesario
local function ScanWeapons()
    pcall(function()
        gunCache = {} -- Limpiamos caché viejo para no saturar memoria
        for _, v in pairs(getgc(true)) do
            if type(v) == "table" and rawget(v, "gunName") then
                table.insert(gunCache, v)
            end
        end
    end)
end

-- Escanear si te equipas un arma nueva (Así nos ahorramos el loop pesado)
local function SetupCharacter(char)
    char.ChildAdded:Connect(function(obj)
        if obj:IsA("Tool") then
            task.wait(0.5) -- Esperamos a que el arma cargue sus datos
            ScanWeapons()
        end
    end)
end

if Player.Character then SetupCharacter(Player.Character) end
