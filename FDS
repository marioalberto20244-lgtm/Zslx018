-- // 🛡️ WALL CHECK FIXED // --
local function IsVisible(part, char)
    if not _G.Z_Aimbot_WallCheck then return true end
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character, char}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local res = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position), params)
    return res == nil
end

-- // 🎯 BUSCADOR CSC AUTO-INTELIGENTE // --
local targetPart = nil
local lastSearch = 0

local function GetTarget()
    -- Optimización: Solo calcula todo 10 veces por segundo
    if tick() - lastSearch < 0.1 then return targetPart end
    lastSearch = tick()

    local maxFOV = _G.Z_Aimbot_FOV or 120
    local center = Camera.ViewportSize / 2
    local newTarget = nil

    -- 🔍 AUTO DETECCIÓN DE TU EQUIPO ACTUAL
    local myTeam = LocalPlayer.Team and LocalPlayer.Team.Name or ""
    local iAmLaw = (myTeam == "Border Patrol" or myTeam == "US Army" or myTeam == "FBI" or myTeam == "BORTAC" or myTeam == "State Trooper" or myTeam == "HSI")
    local iAmCivil = (myTeam == "Civilian" or myTeam == "Civil")

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local char = p.Character
            local part = char:FindFirstChild(_G.Z_Aimbot_Part or "Head")
            local hum = char:FindFirstChildOfClass("Humanoid")
            
            if part and hum and hum.Health > 0 then
                -- 📏 FILTRO STUDS
                local root = char:FindFirstChild("HumanoidRootPart")
                if not root then continue end
                local dist3D = (LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude
                if dist3D > (_G.Z_MaxStuds or 500) then continue end

                -- 🤖 AUTO TEAM CHECK (LA MAGIA)
                if _G.Z_Aimbot_TeamCheck then
                    local otherTeam = p.Team and p.Team.Name or ""
                    local targetIsLaw = (otherTeam == "Border Patrol" or otherTeam == "US Army" or otherTeam == "FBI" or otherTeam == "BORTAC" or otherTeam == "State Trooper" or otherTeam == "HSI")
                    local targetIsCivil = (otherTeam == "Civilian" or otherTeam == "Civil")

                    -- Lógica de combate (Si soy Ley, solo civiles. Si soy civil, solo Ley).
                    if iAmLaw and not targetIsCivil then continue end
                    if iAmCivil and not targetIsLaw then continue end
                    -- Si no soy ni Ley ni Civil (ej. neutral), ignoro a todos por seguridad
                    if not iAmLaw and not iAmCivil then continue end
                end

                -- 👁️ FOV Y WALL CHECK
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distFOV = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if distFOV < maxFOV then
                        if IsVisible(part, char) then
                            maxFOV = distFOV
                            newTarget = part
                        end
                    end
                end
            end
        end
    end
    targetPart = newTarget
    return targetPart
end

-- // 🔄 LOOP MAESTRO // --
local mainLoop = RunService.RenderStepped:Connect(function()
    local center = Camera.ViewportSize / 2
    local fovDist = _G.Z_Aimbot_FOV or 120
    local active = _G.Z_Aimbot_Active
    local showFOV = _G.Z_Aimbot_ShowFOV and active
    
    for i = 1, 16 do FOVLines[i].Visible = false end

    -- 🎨 DIBUJAR FOV LITE
    if showFOV then
        local shape = _G.Z_FOV_Shape or "Circulo"
        if shape == "Circulo" then
            for i = 1, 16 do
                local a1, a2 = math.rad((i-1)*22.5), math.rad(i*22.5)
                FOVLines[i].From = center + Vector2.new(math.cos(a1)*fovDist, math.sin(a1)*fovDist)
                FOVLines[i].To = center + Vector2.new(math.cos(a2)*fovDist, math.sin(a2)*fovDist)
                FOVLines[i].Visible = true
            end
        elseif shape == "Cuadrado" then
            local p = {
                center + Vector2.new(-fovDist, -fovDist), center + Vector2.new(fovDist, -fovDist),
                center + Vector2.new(fovDist, fovDist), center + Vector2.new(-fovDist, fovDist)
            }
            for i = 1, 4 do
                FOVLines[i].From = p[i]; FOVLines[i].To = p[i%4+1]; FOVLines[i].Visible = true
            end
        elseif shape == "Estrella" then
            local pts = {}
            for i = 1, 10 do
                local r = (i%2==0) and fovDist or (fovDist*0.45)
                local a = math.rad((i*36)-90)
                table.insert(pts, center + Vector2.new(math.cos(a)*r, math.sin(a)*r))
            end
            for i = 1, 10 do
                FOVLines[i].From = pts[i]; FOVLines[i].To = pts[i%10+1]; FOVLines[i].Visible = true
            end
        end
    end

    -- 🎯 AIMBOT LITE
    if active then
        local target = GetTarget()
        if target then
            local smooth = _G.Z_Aimbot_Smoothing or 5
            local lookAt = CFrame.new(Camera.CFrame.Position, target.Position)
            Camera.CFrame = Camera.CFrame:Lerp(lookAt, 1 / smooth)
        end
    end
end)

table.insert(connections, mainLoop)
