-- // 🚀 CEREBRO: VEHICLE FLY "REAL GOD" (BODY MOVERS) // --
local RunService = game:GetService("RunService")
local LocalPlayer = game.Players.LocalPlayer

-- Variables para los soportes físicos
local b_vel = nil
local b_gyro = nil

local function lerp(a, b, t)
    return a + (b - a) * t
end

-- Función para limpiar los soportes al bajar o apagar
local function CleanMovers()
    if b_vel then b_vel:Destroy(); b_vel = nil end
    if b_gyro then b_gyro:Destroy(); b_gyro = nil end
end

RunService.RenderStepped:Connect(function()
    -- Reset si el hack está apagado
    if not _G.Z_Vehicle_Active then 
        CleanMovers()
        if workspace.CurrentCamera.FieldOfView ~= 70 then
            workspace.CurrentCamera.FieldOfView = lerp(workspace.CurrentCamera.FieldOfView, 70, 0.1)
        end
        return 
    end
    
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local camera = workspace.CurrentCamera

    if hum and hum.SeatPart and hum.SeatPart:IsA("VehicleSeat") then
        local seat = hum.SeatPart
        local speed = _G.Z_Vehicle_Speed or 50
        
        -- 🛡️ CREAR SOPORTES SI NO EXISTEN
        if not b_vel then
            b_vel = Instance.new("BodyVelocity")
            b_vel.MaxForce = Vector3.new(1, 1, 1) * math.huge
            b_vel.Velocity = Vector3.new(0, 0, 0)
            b_vel.Parent = seat
        end
        
        if not b_gyro then
            b_gyro = Instance.new("BodyGyro")
            b_gyro.MaxTorque = Vector3.new(1, 1, 1) * math.huge
            b_gyro.D = 500 -- Suavizado de giro
            b_gyro.P = 3000 -- Fuerza de estabilidad
            b_gyro.CFrame = seat.CFrame
            b_gyro.Parent = seat
        end

        -- 🔥 MOTOR FLY REAL 🔥
        
        -- 1. FIJAR ROTACIÓN (Gira con la cámara pero siempre NIVELADO)
        local camLook = camera.CFrame.LookVector
        local flatLook = Vector3.new(camLook.X, 0, camLook.Z).Unit
        b_gyro.CFrame = CFrame.new(seat.Position, seat.Position + flatLook)

        if seat.Throttle ~= 0 then
            -- 2. MOVIMIENTO HACIA DONDE VES
            local moveDir = camera.CFrame.LookVector
            if seat.Throttle == -1 then moveDir = -moveDir end
            
            b_vel.Velocity = moveDir * speed
            
            -- FOV de velocidad
            local targetFOV = 70 + (speed / 8)
            camera.FieldOfView = lerp(camera.FieldOfView, targetFOV, 0.1)
        else
            -- 3. MODO ANCLA ABSOLUTA (No cae, no se mueve)
            b_vel.Velocity = Vector3.new(0, 0, 0)
            camera.FieldOfView = lerp(camera.FieldOfView, 70, 0.1)
        end
        
        -- Limpieza de fuerzas externas para evitar el "Spin"
        seat.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        seat.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        
    else
        CleanMovers()
        if camera.FieldOfView ~= 70 then
            camera.FieldOfView = lerp(camera.FieldOfView, 70, 0.1)
        end
    end
end)



















