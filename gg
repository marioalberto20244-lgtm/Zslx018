-- // 3. BUSCADOR INTELIGENTE // --
local function GetMurderer()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if getgenv().RoleCache[p.Name] and getgenv().RoleCache[p.Name].Role == "Murderer" then
                local hum = p.Character:FindFirstChild("Humanoid")
                if hum and hum.Health > 0 then
                    return p.Character.HumanoidRootPart
                end
            end
        end
    end
    return nil
end

RunService.RenderStepped:Connect(function()
    if getgenv().AutoShoot_Active or getgenv().ManualShoot_Active then
        getgenv().CurrentTarget = GetMurderer()
    else
        getgenv().CurrentTarget = nil
    end
end)

-- // 4. WALLCHECK // --
local function IsVisible(targetPart)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("Head") then return false end
    
    local origin = char.Head.Position
    local direction = (targetPart.Position - origin)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char, Workspace.CurrentCamera}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local result = Workspace:Raycast(origin, direction, raycastParams)
    
    if not result or result.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end
    return false
end

-- // 5. SISTEMA DE EJECUCIÓN (CON COOLDOWN REALISTA Y FIX MANUAL) // --
local lastShot = 0
local shotCooldown = 4 -- ⏱️ 4 SEGUNDOS DE ESPERA PARA RECARGAR
local isShooting = false

local function ExecuteKill(isAuto)
    local now = tick()
    if isShooting or (now - lastShot < shotCooldown) then return end
    
    local char = LocalPlayer.Character
    local backpack = LocalPlayer.Backpack
    local target = getgenv().CurrentTarget
    
    if not char or not target then return end
    
    local gun = char:FindFirstChild("Gun") or backpack:FindFirstChild("Gun")
    if gun then
        -- MODO AUTO: Saca el arma automáticamente
        if isAuto and gun.Parent ~= char then
            isShooting = true
            char.Humanoid:EquipTool(gun)
            task.wait(0.3) -- Espera a que la animación de sacar arma termine
        end

        -- MODO MANUAL: Si NO tienes el arma en la mano, no hace nada
        if not isAuto and gun.Parent ~= char then return end

        local shoot = gun:FindFirstChild("Shoot")
        if shoot then
            isShooting = true
            local Prediction = 0.175
            local TargetPos = target.Position + (target.AssemblyLinearVelocity * Prediction)
            
            -- Disparo directo y certero
            shoot:FireServer(char.HumanoidRootPart.CFrame, CFrame.new(TargetPos))
            lastShot = tick() -- Empiezan a contar los 4 segundos
            
            -- Solo guarda el arma si está en modo automático
            if isAuto then
                task.wait(0.1)
                gun.Parent = backpack
            end
        end
        
        task.wait(0.5)
        isShooting = false
    end
end

-- // 6. MODO AUTO: BUCLE ASESINO // --
task.spawn(function()
