-- PC: Secuestramos el click del mouse para que la pistola nativa no dispare a lo tonto
ContextActionService:BindActionAtPriority("ZBeta_ManualShoot", function(actionName, inputState, inputObject)
    if inputState == Enum.UserInputState.Begin and getgenv().ManualShoot_Active then
        local char = LocalPlayer.Character
        -- Solo secuestramos el click si tienes el arma equipada y el Murderer está vivo
        if char and char:FindFirstChild("Gun") and getgenv().CurrentTarget then
            ExecuteKill(false) -- False significa que es Manual
            return Enum.ContextActionResult.Sink -- 🛑 ESTO BLOQUEA LA PISTOLA NATIVA
        end
    end
    return Enum.ContextActionResult.Pass
end, false, Enum.ContextActionPriority.High.Value + 10, Enum.UserInputType.MouseButton1)

