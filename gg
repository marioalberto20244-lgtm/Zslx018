-- Variable para guardar lo que eliges en la lista y si el botón está prendido
local ModoElegido = "Auto"
local SwitchPrendido = false

-- Esta función hace que todo se actualice EN CORTO
local function ActualizarEnCorto()
    if SwitchPrendido then
        -- Actualiza el modo (Auto o Manual)
        if ModoElegido == "Auto" then
            getgenv().AutoShoot_Active = true
            getgenv().ManualShoot_Active = false
        elseif ModoElegido == "Manual" then
            getgenv().AutoShoot_Active = false
            getgenv().ManualShoot_Active = true
        end
    else
        -- Si apagas el botón, se apagan los dos de golpe
        getgenv().AutoShoot_Active = false
        getgenv().ManualShoot_Active = false
    end
end

