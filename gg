end)

-- // 7. MODO MANUAL: INTERCEPTOR VELOCIDAD DE LA LUZ 🔥 // --
ContextActionService:BindActionAtPriority("ZBeta_ManualShoot", function(actionName, inputState, inputObject)
    if inputState == Enum.UserInputState.Begin and getgenv().ManualShoot_Active then
        local char = LocalPlayer.Character
        local target = getgenv().CurrentTarget
        
        if char and target then
            -- Verificamos si tienes la pistola en la mano con el buscador agresivo
            local gunInHand, _ = FindWeaponAndRemote(char)
            if gunInHand then
                -- Filtro para Móvil: Ignorar joystick (Mitad izquierda)
                if inputObject.UserInputType == Enum.UserInputType.Touch then
                    local screenSize = Workspace.CurrentCamera.ViewportSize
                    if inputObject.Position.X < (screenSize.X / 2) then
                        return Enum.ContextActionResult.Pass
                    end
                end

                ExecuteKill(false) 
                return Enum.ContextActionResult.Pass 
            end
        end
    end
    return Enum.ContextActionResult.Pass
end, false, Enum.ContextActionPriority.High.Value + 100, Enum.UserInputType.MouseButton1, Enum.UserInputType.Touch)
























