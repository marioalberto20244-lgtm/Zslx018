    end
end)

-- // 3. WALLCHECK // --
local function IsVisible(targetPart)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("Head") then return false end
    
    local origin = char.Head.Position
    local direction = (targetPart.Position - origin)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {char, Workspace.CurrentCamera}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local result = Workspace:Raycast(origin, direction, raycastParams)
    
    if not result or result.Instance:IsDescendantOf(targetPart.Parent) then
        return true
    end
    return false
end

-- // 4. BUSCADOR AGRESIVO DE ARMAS (NUEVO FIX) // --
local function FindWeaponAndRemote(folder)
    for _, item in pairs(folder:GetChildren()) do
        -- Busca cualquier herramienta que se llame Gun o contenga "Shoot"
        if item:IsA("Tool") and (item.Name:match("Gun") or item:FindFirstChild("Shoot")) then
            local remote = item:FindFirstChild("Shoot")
            -- Si el Shoot está escondido adentro de una carpeta, lo encuentra
            if not remote then
                for _, desc in pairs(item:GetDescendants()) do
                    if desc:IsA("RemoteEvent") and (desc.Name == "Shoot" or desc.Name == "FireServer") then
                        remote = desc
                        break
                    end
                end
            end
            if remote then return item, remote end
        end
    end
    return nil, nil
end

-- // 5. SISTEMA DE EJECUCIÓN (FIX SUPREMO) // --
local lastShot = 0
local shotCooldown = 2 -- ⏱️ Bajado a 2 segundos para duelos rápidos
local isShooting = false

local function ExecuteKill(isAuto)
    local char = LocalPlayer.Character
    local backpack = LocalPlayer.Backpack
    local target = getgenv().CurrentTarget
    
    if not char or not target then return end
    
    -- Usamos el buscador agresivo que no falla
    local gun, shoot = FindWeaponAndRemote(char)
    if not gun then
        gun, shoot = FindWeaponAndRemote(backpack)
    end
    
    if not gun or not shoot then return end

    if isAuto then
        -- MODO AUTO
        local now = tick()
        if isShooting or (now - lastShot < shotCooldown) then return end
        
        if gun.Parent ~= char then
            isShooting = true
            char.Humanoid:EquipTool(gun)
            task.wait(0.3)
        end

        isShooting = true
        local Prediction = 0.175
        local TargetPos = target.Position + (target.AssemblyLinearVelocity * Prediction)
        shoot:FireServer(char.HumanoidRootPart.CFrame, CFrame.new(TargetPos))
        lastShot = tick() 
        
        task.wait(0.1)
        gun.Parent = backpack
        
        task.wait(0.5)
        isShooting = false
    else
        -- MODO MANUAL: ¡Disparo instantáneo a la velocidad de la luz!
        if gun.Parent == char then
            local Prediction = 0.175
            local TargetPos = target.Position + (target.AssemblyLinearVelocity * Prediction)
            shoot:FireServer(char.HumanoidRootPart.CFrame, CFrame.new(TargetPos))
            lastShot = tick()
        end
    end
end

-- // 6. MODO AUTO: BUCLE ASESINO // --
