-- // 2. BUSCADOR DE DUELOS (EL MÁS CERCANO) // --
local function GetClosestPlayer()
    local target = nil
    local dist = math.huge
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 and not p.Character:FindFirstChildOfClass("ForceField") then
                local d = (p.Character.HumanoidRootPart.Position - myChar.HumanoidRootPart.Position).Magnitude
                if d < dist then
                    dist = d
                    target = p.Character.HumanoidRootPart
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    if getgenv().AutoShoot_Active or getgenv().ManualShoot_Active then
        getgenv().CurrentTarget = GetClosestPlayer()
    else
        getgenv().CurrentTarget = nil
    end
end)

-- // 3. BUSCADOR AGRESIVO DE DEFAULTGUN // --
local function GetWeapon()
    local char = LocalPlayer.Character
    local backpack = LocalPlayer.Backpack
    local gun = (char and char:FindFirstChild("DefaultGun")) or backpack:FindFirstChild("DefaultGun")
    
    if not gun then
        for _, item in pairs(char:GetChildren()) do if item:IsA("Tool") and item.Name:match("Gun") then gun = item break end end
    end
    if not gun then
        for _, item in pairs(backpack:GetChildren()) do if item:IsA("Tool") and item.Name:match("Gun") then gun = item break end end
    end

    if gun then
        local remote = gun:FindFirstChild("Shoot") or gun:FindFirstChildOfClass("RemoteEvent")
        return gun, remote
    end
    return nil, nil
end

-- // 4. SISTEMA DE EJECUCIÓN (FIX DE BALA INVISIBLE Y DAÑO) // --
local lastShot = 0
local cooldown = 1.5 
local isShooting = false

local function ExecuteKill(isAuto)
    local target = getgenv().CurrentTarget
    local char = LocalPlayer.Character
    if not target or not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local gun, shoot = GetWeapon()
    if not gun or not shoot then return end

    local now = tick()
    if isShooting or (now - lastShot < cooldown) then return end

    if isAuto and gun.Parent ~= char then
        isShooting = true
        char.Humanoid:EquipTool(gun)
        task.wait(0.2)
    end

    if not isAuto and gun.Parent ~= char then return end

    isShooting = true
    
    local Prediction = 0.18
    local TargetPos = target.Position + (target.AssemblyLinearVelocity * Prediction)
    
    -- Giramos el pecho hacia el enemigo para el servidor
    char.HumanoidRootPart.CFrame = CFrame.lookAt(char.HumanoidRootPart.Position, Vector3.new(TargetPos.X, char.HumanoidRootPart.Position.Y, TargetPos.Z))

    -- 🔥 LA MAGIA CONTRA LA BALA INVISIBLE:
    -- Buscamos el cañón de la pistola. Si no, aventamos el tiro 2 metros al frente.
    local originCFrame
    if gun:FindFirstChild("Handle") then
        originCFrame = gun.Handle.CFrame
    else
        originCFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, 0, -2)
    end

    -- Disparamos desde el cañón hacia el enemigo
    shoot:FireServer(originCFrame, CFrame.new(TargetPos))
    
    lastShot = tick()
    
    if isAuto then
        task.wait(0.1)
        gun.Parent = LocalPlayer.Backpack
    end
    
    task.wait(0.2)
    isShooting = false
end

-- // 5. BUCLE AUTO // --
task.spawn(function()
    while true do
        task.wait(0.05)
        if getgenv().AutoShoot_Active then
            ExecuteKill(true)
        end
    end
end)

-- // 6. GATILLO MANUAL // --
ContextActionService:BindActionAtPriority("ZBeta_DuelShoot", function(name, state, input)
    if state == Enum.UserInputState.Begin and getgenv().ManualShoot_Active then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("DefaultGun") and getgenv().CurrentTarget then
            if input.UserInputType == Enum.UserInputType.Touch then
                if input.Position.X < (Workspace.CurrentCamera.ViewportSize.X / 2) then
                    return Enum.ContextActionResult.Pass
                end
            end
            ExecuteKill(false)
        end
    end
    return Enum.ContextActionResult.Pass
end, false, Enum.ContextActionPriority.High.Value + 100, Enum.UserInputType.MouseButton1, Enum.UserInputType.Touch)



















