-- // 2. BUSCADOR DE DUELOS (EL MÁS CERCANO) // --
local function GetClosestPlayer()
    local target = nil
    local dist = math.huge
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 and not p.Character:FindFirstChildOfClass("ForceField") then
                local d = (p.Character.HumanoidRootPart.Position - myChar.HumanoidRootPart.Position).Magnitude
                if d < dist then
                    dist = d
                    target = p.Character:FindFirstChild("Head") or p.Character.HumanoidRootPart
                end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    if getgenv().AutoShoot_Active or getgenv().ManualShoot_Active then
        getgenv().CurrentTarget = GetClosestPlayer()
    else
        getgenv().CurrentTarget = nil
    end
end)

-- // 3. EL HOOK SEGURO (MÉTODO PARA ENGAÑAR A LA BALA ORIGINAL SIN CRASHEAR XENO) // --
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    -- Si el juego intenta mandar la bala original al servidor...
    if method == "FireServer" and tostring(self) == "Shoot" and (getgenv().AutoShoot_Active or getgenv().ManualShoot_Active) then
        local target = getgenv().CurrentTarget
        local char = LocalPlayer.Character
        
        -- Si tenemos un objetivo y tenemos la pistola en la mano...
        if target and char and char:FindFirstChild("DefaultGun") then
            local Prediction = 0.18
            local TargetPos = target.Position + (target.AssemblyLinearVelocity * Prediction)
            
            -- Redirigimos la BALA ORIGINAL hacia la cabeza. 
            -- No creamos una bala falsa, modificamos la que el juego ya creó.
            if type(args[1]) == "CFrame" and type(args[2]) == "CFrame" then
                args[2] = CFrame.new(TargetPos) -- Cambiamos el destino al objetivo
                return oldNamecall(self, unpack(args))
            elseif type(args[1]) == "Vector3" then
                args[1] = TargetPos -- Por si acaso pide solo la posición
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)

-- // 4. SISTEMA DE EJECUCIÓN // --
-- Como usamos Hook, nosotros no disparamos, solo forzamos el click (simulación real)
local isShooting = false
local function ExecuteKill(isAuto)
    local target = getgenv().CurrentTarget
    local char = LocalPlayer.Character
    if not target or not char then return end

    local gun = char:FindFirstChild("DefaultGun") or LocalPlayer.Backpack:FindFirstChild("DefaultGun")
    if not gun then return end

    if isAuto and gun.Parent ~= char then
        isShooting = true
        char.Humanoid:EquipTool(gun)
        task.wait(0.2)
    end

    if not isAuto and gun.Parent ~= char then return end

    isShooting = true
    
    -- Simulamos un click izquierdo "Virtual" usando las funciones de la pistola misma.
    -- Esto hará que el juego genere su bala visual real, y nuestro Hook (Bloque 3) la redirigirá.
    gun:Activate()
    
    if isAuto then
        task.wait(0.1)
        gun:Deactivate()
        task.wait(0.1)
        gun.Parent = LocalPlayer.Backpack
    end
    
    task.wait(0.2)
    isShooting = false
end

-- // 5. BUCLE AUTO // --
task.spawn(function()
    while true do
        task.wait(0.1)
        if getgenv().AutoShoot_Active then
            ExecuteKill(true)
        end
    end
end)

-- // 6. GATILLO MANUAL (RESTAURADO A USERINPUTSERVICE PARA NO BLOQUEAR LA BALA REAL) // --
local TouchStart = 0
local StartPos = Vector2.new(0,0)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end 
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and getgenv().ManualShoot_Active then 
        local screenSize = Workspace.CurrentCamera.ViewportSize
        -- Filtro Joystick para móvil
        if input.UserInputType == Enum.UserInputType.Touch and input.Position.X < (screenSize.X / 2) then return end
        
        TouchStart = tick()
        StartPos = input.Position 
    end
end)

UserInputService.InputEnded:Connect(function(input, gp)
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) and getgenv().ManualShoot_Active then
        local Dur = tick() - TouchStart
        local Dist = (Vector2.new(input.Position.X, input.Position.Y) - Vector2.new(StartPos.X, StartPos.Y)).Magnitude
        
        -- Si fue un click rápido (no arrastrar) y estamos en modo manual
        if Dur < 0.25 and Dist < 20 and not isShooting then 
            local screenSize = Workspace.CurrentCamera.ViewportSize
            if input.UserInputType == Enum.UserInputType.Touch and input.Position.X < (screenSize.X / 2) then return end
            
            if getgenv().CurrentTarget then
                -- No hacemos ExecuteKill aquí porque tú ya diste el click real, 
                -- el Hook arriba se encargará de atrapar tu bala.
            end
        end
    end
end)


























