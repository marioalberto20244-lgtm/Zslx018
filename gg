-- // 2. BUSCADOR PSICÓPATA (EL MÁS CERCANO) // --
local function GetClosestTarget()
    local closestTarget = nil
    local shortestDistance = math.huge 
    
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = myChar.HumanoidRootPart.Position

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            
            -- Si está vivo y no tiene campo de fuerza que lo haga invencible
            if hum and hum.Health > 0 and not p.Character:FindFirstChildOfClass("ForceField") then
                local targetPos = p.Character.HumanoidRootPart.Position
                local distance = (targetPos - myPos).Magnitude
                
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestTarget = p.Character.HumanoidRootPart
                end
            end
        end
    end
    
    return closestTarget
end

